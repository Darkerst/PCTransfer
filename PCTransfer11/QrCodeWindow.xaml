<Window x:Class="PCTransfer11.QrCodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PCTransfer11 - PIN als QR-code" Height="420" Width="340"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <StackPanel Margin="20" HorizontalAlignment="Center">
        <TextBlock Text="Scan met de PCTransfer11-app op je telefoon:"
                   TextWrapping="Wrap" Margin="0,0,0,12"/>
        <Border BorderBrush="#CCCCCC" BorderThickness="1" HorizontalAlignment="Center">
            <Image x:Name="QrImage" Width="300" Height="300"
                   RenderOptions.BitmapScalingMode="NearestNeighbor"
                   Stretch="Uniform"/>
        </Border>
        <TextBlock x:Name="PinLabel" FontSize="24" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,12,0,8"/>
        <TextBlock Text="Of typ de PIN hierboven over op de andere app."
                   Style="{StaticResource SubtleText}"
                   TextWrapping="Wrap" TextAlignment="Center"/>
        <Button Content="Sluiten" IsCancel="True" Margin="0,12,0,0"
                Click="Close_Click"/>
    </StackPanel>
</Window>
