<Window x:Class="PCTransfer11.QrCodeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PCTransfer11 - PIN als QR-code" Height="340" Width="320"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <StackPanel Margin="20" HorizontalAlignment="Center">
        <TextBlock Text="Scan met de PCTransfer11-app op je telefoon:" TextWrapping="Wrap" Margin="0,0,0,12"/>
        <Canvas x:Name="QrCanvas" Width="240" Height="240" Background="White" Margin="0,0,0,12"/>
        <TextBlock x:Name="PinLabel" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
        <TextBlock Text="Of typ de PIN hierboven over op de andere app."
                   Style="{StaticResource SubtleText}" TextWrapping="Wrap" TextAlignment="Center"/>
        <Button Content="Sluiten" IsCancel="True" Margin="0,12,0,0" Click="Close_Click"/>
    </StackPanel>
</Window>
