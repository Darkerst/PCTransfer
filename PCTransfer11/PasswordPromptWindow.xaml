<Window x:Class="PCTransfer11.PasswordPromptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PCTransfer11" Height="200" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="PromptText" Grid.Row="0" TextWrapping="Wrap" Margin="0,0,0,12" Text="Wachtwoord:"/>
        <PasswordBox x:Name="PasswordInput" Grid.Row="1" Padding="6" KeyDown="PasswordInput_KeyDown"/>
        <TextBlock x:Name="ErrorText" Grid.Row="2" Foreground="Red" Margin="0,6,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Annuleren" Width="90" Margin="0,0,8,0" Click="Cancel_Click" IsCancel="True"/>
            <Button Content="OK" Width="90" Click="Ok_Click" IsDefault="True"/>
        </StackPanel>
    </Grid>
</Window>
